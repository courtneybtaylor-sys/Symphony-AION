# Symphony AION Environment Configuration
# Copy this file to .env.local and update values for your environment

# =============================================================================
# Next.js Configuration
# =============================================================================
NEXT_PUBLIC_AION_VERSION=1.0.0

# =============================================================================
# API Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=30000

# =============================================================================
# Database Configuration (Future - Not Required for Development)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/symphony_aion
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# =============================================================================
# Feature Flags
# =============================================================================
# Enable mock data for development (set to false to use real data source)
NEXT_PUBLIC_ENABLE_MOCK_DATA=true

# Enable billing analytics features
NEXT_PUBLIC_ENABLE_BILLING_ANALYTICS=true

# Enable advanced telemetry visualization
NEXT_PUBLIC_ENABLE_TELEMETRY_ADVANCED=true

# =============================================================================
# Observability & Logging
# =============================================================================
# Log level: debug, info, warn, error
NEXT_PUBLIC_LOG_LEVEL=info

# Enable analytics collection (respects privacy settings)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Enable error tracking (e.g., Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project

# =============================================================================
# Authentication (Future - Phase 2)
# =============================================================================
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-key-here

# =============================================================================
# Third-Party Service Integrations (Future)
# =============================================================================
# Stripe for billing
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# AWS for storage (S3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# =============================================================================
# AI Model Provider Keys (Optional)
# =============================================================================
# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Groq
# GROQ_API_KEY=gsk_...

# =============================================================================
# Development-only Settings
# =============================================================================
# Set to true to skip type checking during dev builds
TYPESCRIPT_IGNORE_BUILD_ERRORS=false

# Next.js experimental features
NEXT_PUBLIC_EXPERIMENTAL_APP_DIR=true
