# Symphony-AION Environment Configuration
# Copy this file to .env.local and update values for your environment

# ============================================================================
# DEMO MODE (Phase 6: Development/Testing)
# ============================================================================
# Enable demo mode to bypass authentication for development
# When true: All routes accessible without login, demo user has admin privileges
# When false: Requires proper authentication setup
NEXT_PUBLIC_DEMO_MODE=true

# ============================================================================
# DATABASE (Phase 4b: Database Integration)
# ============================================================================
# PostgreSQL connection string for Prisma
# Development: postgresql://user:password@localhost:5432/symphony_aion
# Production: Use Neon or AWS RDS with connection pooling
DATABASE_URL=postgresql://postgres:password@localhost:5432/symphony_aion

# ============================================================================
# AUTHENTICATION (Phase 4a: NextAuth.js)
# ============================================================================
# NextAuth secret for JWT signing - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32

# NextAuth URL - the domain where the app is hosted
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# ADMIN SECURITY (Phase 4g: Admin Endpoint Protection)
# ============================================================================
# Secret key for protecting admin endpoints
ADMIN_SECRET=your-admin-secret-key

# ============================================================================
# REDIS / JOB QUEUE (Phase 4c: Bull Queue)
# ============================================================================
# Redis connection string for background job processing
# Development: redis://localhost:6379
# Production: Use Upstash Redis
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# IR-PARSER BACKEND (Phase 5: Backend Integration)
# ============================================================================
# URL where the FastAPI IR-Parser backend is running
IR_PARSER_URL=http://localhost:8000

# ============================================================================
# STRIPE PAYMENTS (Phase 4f: Payment Processing)
# ============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PRICE_ID=price_your_price_id_here

# ============================================================================
# EMAIL DELIVERY (Task 4: Real Email with Resend)
# ============================================================================
# Resend API key for sending audit report emails
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================================================
# VERCEL BLOB STORAGE (FIX 3: PDF Storage)
# ============================================================================
# Vercel Blob storage token for storing audit PDFs
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# ============================================================================
# APP URL (For email links and redirects)
# ============================================================================
# Public app URL used in email links and redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# LOGGING & DEBUG (Optional)
# ============================================================================
# Enable verbose logging in development
DEBUG=false

