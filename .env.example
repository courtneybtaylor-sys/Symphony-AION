# Symphony AION Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# Next.js Configuration
# =============================================================================
NEXT_PUBLIC_AION_VERSION=0.2.0
NEXT_PUBLIC_DEMO_MODE=true

# =============================================================================
# API Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=30000

# =============================================================================
# Database Configuration (Phase 4b, Task 1 - PostgreSQL)
# =============================================================================
# Development: PostgreSQL local
DATABASE_URL="postgresql://postgres:password@localhost:5432/symphony_aion_dev"
# Production: PostgreSQL with connection pooling
# DATABASE_URL="postgresql://user:password@host:5432/symphony_aion?sslmode=require"
# Test: Separate test database
DATABASE_URL_TEST="postgresql://postgres:password@localhost:5432/symphony_aion_test"

# =============================================================================
# Authentication (Phase 4a)
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-minimum-32-characters

# =============================================================================
# Stripe Configuration (Phase 4f)
# =============================================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_AUDIT_PRICE_ID="price_1234567890"

# =============================================================================
# Email Delivery (Task 4 - Resend)
# =============================================================================
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@symphony-aion.com"

# =============================================================================
# IR-Parser Microservice (Task 7)
# =============================================================================
IR_PARSER_URL="http://localhost:8001"

# =============================================================================
# OAuth (Task 8 - Security Hardening)
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# =============================================================================
# Redis / Job Queue (Task 2 - Distributed Rate Limiting, Task 3 - Bull Queue)
# =============================================================================
# Development: Local Redis
REDIS_URL="redis://localhost:6379"
# Production: Upstash (serverless)
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# =============================================================================
# Rate Limiting (Phase 4d)
# =============================================================================
RATELIMIT_ENABLED=true

# =============================================================================
# CORS (Phase 4h)
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Feature Flags
# =============================================================================
NEXT_PUBLIC_ENABLE_MOCK_DATA=true
NEXT_PUBLIC_ENABLE_BILLING_ANALYTICS=true
NEXT_PUBLIC_ENABLE_TELEMETRY_ADVANCED=true

# =============================================================================
# Observability & Logging
# =============================================================================
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project

# =============================================================================
# AI Model Provider Keys (Optional)
# =============================================================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# =============================================================================
# AWS Storage (Production)
# =============================================================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# =============================================================================
# Development-only Settings
# =============================================================================
TYPESCRIPT_IGNORE_BUILD_ERRORS=false
NEXT_PUBLIC_EXPERIMENTAL_APP_DIR=true
