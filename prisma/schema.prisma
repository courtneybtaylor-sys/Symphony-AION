// Symphony-AION Database Schema
// Phase 4b: PostgreSQL with Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  password         String?
  name             String?
  subscriptionTier String     @default("free")
  // Role-based access control
  role             String     @default("user") // user, admin, super_admin
  // Task 8: MFA fields
  mfaEnabled       Boolean    @default(false)
  mfaSecret        String?    // TOTP secret (base32 encoded)
  mfaBackupCodes   String[]   @default([]) // Array of backup codes
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  uploads          Upload[]
  auditJobs        AuditJob[]
  auditLogs        AuditLog[]

  @@index([email])
  @@index([role])
}

model Upload {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  telemetry    Json      @db.JsonB                // Native PostgreSQL JSONB for better query performance
  hash         String    @unique
  framework    String?
  modelCount   Int?
  totalCostUSD Float?
  createdAt    DateTime  @default(now())
  auditJob     AuditJob?

  @@index([userId])
  @@index([createdAt])
}

model AuditJob {
  id                   String    @id @default(cuid())
  uploadId             String    @unique
  upload               Upload    @relation(fields: [uploadId], references: [id])
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  stripeSessionId      String?   @unique
  status               String    @default("queued")                               // queued, processing, completed, failed, pending_payment
  aeiScore             Json?                                                      // Full AEI score breakdown
  recommendations      Json?                                                      // Array of recommendations
  reportToken          String?   @unique
  reportTokenExpiresAt DateTime?
  reportPath           String?
  error                String?
  createdAt            DateTime  @default(now())
  completedAt          DateTime?

  @@index([userId])
  @@index([status])
  @@index([reportTokenExpiresAt])
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  userId    String?
  eventType String
  metadata  Json?    @db.JsonB                                // Native PostgreSQL JSONB
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId, eventType])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String                                            // upload_telemetry, create_checkout, payment_completed, etc.
  resource  String?                                           // uploadId, auditJobId, etc.
  ipAddress String?
  userAgent String?  @db.VarChar(500)
  result    String                                            // success, failure, blocked
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([result])
}
